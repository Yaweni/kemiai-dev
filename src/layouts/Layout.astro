---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n';

export interface Props {
  title: string;
  lang: Lang;
  t: Record<string, any>;
  description?: string;
}

const { title, lang, t, description } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — KEMI AI</title>
    <meta name="description" content={description ?? "KEMI AI — Digital transformation agency. AI, data, and digitization for the modern enterprise."} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
    <script>
      (function() {
        var saved = localStorage.getItem('kemiai-theme');
        var theme = saved || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} t={t.nav} />
    <main>
      <slot />
    </main>
    <Footer t={t.footer} lang={lang} />
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="What We Do">
  <section class="page-hero">
    <div class="container">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">What We Do</span>
      <h1 class="page-title">The full <span class="gold-text">transformation</span> stack</h1>
      <p class="page-subtitle">From digitizing your operations to deploying intelligent systems — we cover every layer of the modern data and AI stack with precision and care.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="service-detail">
        <div class="service-tag">01</div>
        <h2 class="service-name">Digitization</h2>
        <p class="service-desc">We convert manual, paper-based, and legacy workflows into scalable digital systems. This is the bedrock — without it, no amount of AI can fix broken processes.</p>
        <div class="service-list">
          <div class="service-item">Process audit & opportunity mapping</div>
          <div class="service-item">Document digitization & intelligent capture</div>
          <div class="service-item">Workflow automation (RPA, BPM)</div>
          <div class="service-item">Legacy system modernization</div>
          <div class="service-item">Cloud migration & infrastructure setup</div>
          <div class="service-item">Data pipeline architecture</div>
        </div>
      </div>

      <div class="service-detail">
        <div class="service-tag">02</div>
        <h2 class="service-name">Numerical Transformation</h2>
        <p class="service-desc">We turn raw data into strategic gold. From real-time dashboards to forecasting engines, we design analytics systems that illuminate your business reality and drive decisions.</p>
        <div class="service-list">
          <div class="service-item">Data strategy & governance frameworks</div>
          <div class="service-item">Business intelligence & dashboard engineering</div>
          <div class="service-item">Predictive analytics & forecasting models</div>
          <div class="service-item">Data warehousing & lakehouse architecture</div>
          <div class="service-item">Statistical modeling & numerical optimization</div>
          <div class="service-item">KPI definition & reporting automation</div>
        </div>
      </div>

      <div class="service-detail">
        <div class="service-tag">03</div>
        <h2 class="service-name">AI Transitioning</h2>
        <p class="service-desc">We integrate intelligence into your products, operations, and customer experiences — from identifying the right use case to deploying and monitoring models in production.</p>
        <div class="service-list">
          <div class="service-item">AI readiness assessment & roadmap</div>
          <div class="service-item">LLM integration & RAG system design</div>
          <div class="service-item">Custom model fine-tuning & deployment</div>
          <div class="service-item">AI agent & copilot development</div>
          <div class="service-item">MLOps & model monitoring infrastructure</div>
          <div class="service-item">AI ethics, safety & compliance frameworks</div>
        </div>
      </div>

      <div class="service-detail featured">
        <div class="service-tag">+</div>
        <h2 class="service-name">Consulting & Strategy</h2>
        <p class="service-desc">Not sure where to begin? We provide vendor-neutral advisory to build a transformation roadmap that respects your budget, timeline, and risk appetite — no overselling, no fluff.</p>
        <div class="service-list">
          <div class="service-item">Technology stack evaluation & selection</div>
          <div class="service-item">Build vs. buy analysis</div>
          <div class="service-item">Digital maturity assessment</div>
          <div class="service-item">Change management & team upskilling</div>
          <div class="service-item">ROI modeling & business case development</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-gold">
    <div class="container" style="text-align: center;">
      <div class="floral-divider" style="--color-gold: var(--color-dark);"><span>&#10086;</span></div>
      <h2 class="section-title">Not sure which service fits?</h2>
      <p class="section-subtitle" style="color: var(--color-brown); margin-left: auto; margin-right: auto;">
        We'll help you figure it out. Book a no-obligation discovery session.
      </p>
      <a href="/contact" class="btn btn-primary" style="background: var(--color-dark); color: var(--color-gold);">Book a Discovery Call</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: var(--color-dark);
    padding: 100px 0 72px;
    text-align: center;
    overflow: hidden;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 160, 23, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-ornament {
    color: var(--color-gold);
    font-size: 1rem;
    letter-spacing: 8px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--color-gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-cream);
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
    z-index: 1;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-amber), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-brown-light);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .service-detail {
    padding: 48px;
    border: 1px solid rgba(212, 160, 23, 0.15);
    border-radius: var(--radius);
    background: var(--color-warm-white);
    margin-bottom: 40px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .service-detail::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--color-gold);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .service-detail:hover {
    border-color: var(--color-gold);
    box-shadow: 0 12px 40px rgba(212, 160, 23, 0.08);
  }

  .service-detail:hover::before {
    opacity: 1;
  }

  .service-detail.featured {
    border: 2px solid var(--color-gold);
    background: linear-gradient(135deg, var(--color-warm-white), rgba(212, 160, 23, 0.03));
  }

  .service-detail.featured::before {
    opacity: 1;
  }

  .service-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-gold), var(--color-amber));
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .service-detail.featured .service-tag {
    background: var(--color-gold);
    color: var(--color-dark);
  }

  .service-name {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-dark);
  }

  .service-desc {
    color: var(--color-brown);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 700px;
    margin-bottom: 28px;
  }

  .service-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .service-item {
    padding: 12px 18px;
    background: var(--color-cream-dark);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--color-brown);
    border: 1px solid rgba(212, 160, 23, 0.08);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .service-list {
      grid-template-columns: 1fr;
    }

    .service-detail {
      padding: 32px 24px;
    }

    .service-name {
      font-size: 1.35rem;
    }
  }
</style>

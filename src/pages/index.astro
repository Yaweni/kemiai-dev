---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">Digital Transformation Agency</span>
      <h1 class="hero-title">
        We turn complexity into<br />
        <span class="gold-text">golden opportunity</span>
      </h1>
      <p class="hero-subtitle">
        KEMI AI blends African ingenuity with artificial intelligence to transform businesses through digitization, data science, and AI integration.
      </p>
      <div class="hero-actions">
        <a href="/services" class="btn btn-primary">Explore Our Work</a>
        <a href="/contact" class="btn btn-outline-light">Get in Touch</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="floral-divider"><span>&#10086;</span></div>
        <h2 class="section-title">What we do</h2>
        <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">
          End-to-end transformation services rooted in deep expertise and delivered with care.
        </p>
      </div>
      <div class="grid-3">
        <ServiceCard
          icon="&#9728;"
          title="Digitization"
          description="We convert paper-based and legacy processes into modern digital workflows. Your operations, reimagined for speed and scale."
        />
        <ServiceCard
          icon="&#9733;"
          title="Numerical Transformation"
          description="We turn raw data into strategic gold. Dashboards, forecasting, and analytics that reveal the story your numbers are telling."
        />
        <ServiceCard
          icon="&#10022;"
          title="AI Transitioning"
          description="We weave intelligence into your products and operations — from LLMs to custom models — making AI practical and profitable."
        />
      </div>
      <div style="text-align: center; margin-top: 56px;">
        <a href="/services" class="btn btn-primary">See Everything We Do &#10095;</a>
      </div>
    </div>
  </section>

  <section class="section section-dark process-section">
    <div class="container" style="text-align: center;">
      <div class="floral-divider" style="--color-gold: var(--color-gold-light);"><span>&#10086;</span></div>
      <h2 class="section-title">How we work</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">
        A process refined across dozens of engagements.
      </p>
    </div>
    <div class="container">
      <div class="steps">
        <div class="step">
          <span class="step-number">1</span>
          <h3>Listen</h3>
          <p>We show up, we listen deeply. No assumptions, no cookie-cutter playbooks. Every engagement starts with understanding your world.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>Design</h3>
          <p>We architect solutions that fit your reality — budget, team, timeline, and ambition. Clean architecture, pragmatic choices.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>Build</h3>
          <p>We execute with craftsmanship. Code, data pipelines, models — built to last, documented, and handed over with pride.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">4</span>
          <h3>Grow</h3>
          <p>We don't disappear after launch. We help you scale, iterate, and own your transformation long-term.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-gold">
    <div class="container" style="text-align: center;">
      <div class="section-header">
        <div class="floral-divider" style="--color-gold: var(--color-dark);"><span>&#10086;</span></div>
        <h2 class="section-title">Ready to build something golden?</h2>
        <p class="section-subtitle" style="color: var(--color-brown); margin-left: auto; margin-right: auto;">
          Whether you're starting from scratch or scaling up, we meet you where you are and take you where you need to go.
        </p>
      </div>
      <a href="/contact" class="btn btn-primary" style="background: var(--color-dark); color: var(--color-gold);">Start a Conversation</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: var(--color-dark);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 15% 50%, rgba(212, 160, 23, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 85% 50%, rgba(232, 168, 23, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(196, 126, 94, 0.06) 0%, transparent 40%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-ornament {
    color: var(--color-gold);
    font-size: 1.2rem;
    letter-spacing: 8px;
    margin-bottom: 24px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--color-gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
  }

  .hero-title {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.12;
    color: var(--color-cream);
    margin-bottom: 24px;
    letter-spacing: -1.5px;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-amber), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-brown-light);
    max-width: 600px;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 16px;
  }

  .section-header .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .process-section {
    padding-top: 100px;
    padding-bottom: 100px;
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-top: 48px;
  }

  .step {
    flex: 1;
    text-align: center;
    padding: 0 16px;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-dark);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }

  .step h3 {
    color: var(--color-gold-light);
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .step p {
    color: var(--color-brown-light);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .step-connector {
    width: 40px;
    height: 2px;
    background: rgba(212, 160, 23, 0.2);
    margin-top: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.4rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .steps {
      flex-direction: column;
      gap: 32px;
    }

    .step-connector {
      display: none;
    }
  }
</style>

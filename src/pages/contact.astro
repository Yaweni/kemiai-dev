---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Talk to Us">
  <section class="page-hero">
    <div class="container">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">Talk to Us</span>
      <h1 class="page-title">Let's build something <span class="gold-text">golden</span> together</h1>
      <p class="page-subtitle">Tell us what you're working on. We'll respond within 48 hours with a thoughtful perspective — not a canned pitch.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="floral-divider"><span>&#10086;</span></div>
          <h2 class="section-title" style="margin-bottom: 32px;">Reach us</h2>
          <div class="info-block">
            <div class="info-icon">&#9993;</div>
            <div>
              <h4>Email</h4>
              <a href="mailto:hello@kemiai.dev">hello@kemiai.dev</a>
            </div>
          </div>
          <div class="info-block">
            <div class="info-icon">&#9200;</div>
            <div>
              <h4>Response Time</h4>
              <p>We reply to every inquiry within 48 hours — usually faster.</p>
            </div>
          </div>
          <div class="info-block">
            <div class="info-icon">&#127758;</div>
            <div>
              <h4>Location</h4>
              <p>Remote-first, globally distributed. We work with clients anywhere in the world.</p>
            </div>
          </div>
        </div>

        <form class="contact-form" action="https://formspree.io/f/your-form-id" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="you@company.com" />
            </div>
          </div>
          <div class="form-group">
            <label for="company">Company (optional)</label>
            <input type="text" id="company" name="company" placeholder="Your company" />
          </div>
          <div class="form-group">
            <label for="message">Tell us about your project</label>
            <textarea id="message" name="message" rows="6" required placeholder="What are you looking to build, transform, or improve? The more detail, the better our first response."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; font-size: 1.05rem;">Send Message</button>
          <p class="form-note">We respect your inbox. No spam, ever.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: var(--color-dark);
    padding: 100px 0 72px;
    text-align: center;
    overflow: hidden;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 160, 23, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-ornament {
    color: var(--color-gold);
    font-size: 1rem;
    letter-spacing: 8px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--color-gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-cream);
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
    z-index: 1;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-amber), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-brown-light);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 64px;
    align-items: start;
  }

  .info-block {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.5rem;
    color: var(--color-gold);
    flex-shrink: 0;
    width: 36px;
    text-align: center;
  }

  .info-block h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-muted);
    margin-bottom: 6px;
  }

  .info-block p, .info-block a {
    font-size: 1rem;
    color: var(--color-dark);
  }

  .contact-form {
    background: var(--color-warm-white);
    border: 1px solid rgba(212, 160, 23, 0.15);
    border-radius: var(--radius);
    padding: 44px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    margin-bottom: 22px;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-dark);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: all 0.2s;
    background: var(--color-cream);
    color: var(--color-dark);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(212, 160, 23, 0.1);
    background: var(--color-warm-white);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-muted);
  }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 18px;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form {
      padding: 28px 20px;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Who We Are">
  <section class="page-hero">
    <div class="container">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">Who We Are</span>
      <h1 class="page-title">Rooted in <span class="gold-text">ingenuity</span>,<br />built for impact</h1>
      <p class="page-subtitle">KEMI AI was born at the intersection of African problem-solving and cutting-edge technology. We exist to make digital transformation practical, accessible, and deeply human.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <div class="floral-divider"><span>&#10086;</span></div>
          <h2 class="section-title">Our Story</h2>
          <p style="color: var(--color-brown); margin-bottom: 16px; font-size: 1rem; line-height: 1.8;">
            The name <strong>KEMI</strong> means "to take care of" in Yoruba — and that is the ethos we bring to every engagement. We take care of your data, your systems, your teams, and your outcomes.
          </p>
          <p style="color: var(--color-brown); margin-bottom: 16px; font-size: 1rem; line-height: 1.8;">
            We started KEMI AI because we saw too many organizations paralyzed by the pace of technological change. Businesses drowning in data they couldn't use. Legacy systems holding back innovation. AI hype without AI impact.
          </p>
          <p style="color: var(--color-brown); font-size: 1rem; line-height: 1.8;">
            So we built an agency that bridges the gap — combining the craft of software engineering with the clarity of strategic consulting. From first audit to final deployment, we bring the same care, rigor, and honesty.
          </p>
        </div>
        <div class="story-visual">
          <div class="story-card">
            <div class="story-stat">20+</div>
            <div class="story-label">Projects Delivered</div>
          </div>
          <div class="story-card">
            <div class="story-stat">5+</div>
            <div class="story-label">Industries Served</div>
          </div>
          <div class="story-card">
            <div class="story-stat">100%</div>
            <div class="story-label">Client Retention</div>
          </div>
          <div class="story-card">
            <div class="story-stat">3</div>
            <div class="story-label">Core Pillars</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container">
      <div style="text-align: center;">
        <div class="floral-divider"><span>&#10086;</span></div>
        <h2 class="section-title">What drives us</h2>
        <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">
          Three principles that guide every decision we make and every project we ship.
        </p>
      </div>
      <div class="grid-3">
        <div class="value-card">
          <span class="value-icon">&#10022;</span>
          <h3 class="value-title">Clarity Over Complexity</h3>
          <p class="value-desc">We speak plainly, design simply, and build things that stakeholders at every level can understand and own. No black boxes.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">&#9733;</span>
          <h3 class="value-title">Measurable Impact</h3>
          <p class="value-desc">Every engagement is tied to business outcomes. If we can't measure it, we don't ship it. Gold standard or nothing.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">&#9728;</span>
          <h3 class="value-title">Future-Proof Delivery</h3>
          <p class="value-desc">We build for tomorrow's scale. Modular architecture, clean data foundations, and AI-native design from day one.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container" style="text-align: center;">
      <div class="floral-divider" style="--color-gold: var(--color-gold-light);"><span>&#10086;</span></div>
      <h2 class="section-title" style="color: var(--color-cream);">The KEMI difference</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto; color: var(--color-brown-light);">
        We're not just technologists. We are translators between business ambition and technical execution.
      </p>
      <div class="diff-grid">
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>Deep listening before any solutioning</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>Engineering + strategy — never one without the other</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>Transparent pricing, honest timelines</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>Africa-rooted, globally minded</p>
        </div>
      </div>
      <a href="/contact" class="btn btn-primary" style="margin-top: 32px;">Work With Us</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: var(--color-dark);
    padding: 100px 0 72px;
    text-align: center;
    overflow: hidden;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 160, 23, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-ornament {
    color: var(--color-gold);
    font-size: 1rem;
    letter-spacing: 8px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--color-gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-cream);
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
    z-index: 1;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-amber), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-brown-light);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .story-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    background: var(--color-cream-dark);
    border-radius: var(--radius);
    padding: 32px;
  }

  .story-card {
    background: var(--color-warm-white);
    border: 1px solid rgba(212, 160, 23, 0.12);
    border-radius: var(--radius);
    padding: 28px 20px;
    text-align: center;
  }

  .story-stat {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-gold-dark);
    line-height: 1;
  }

  .story-label {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 4px;
  }

  .value-card {
    padding: 36px 28px;
    background: var(--color-warm-white);
    border-radius: var(--radius);
    border: 1px solid rgba(212, 160, 23, 0.1);
    text-align: center;
    transition: all 0.3s;
  }

  .value-card:hover {
    border-color: var(--color-gold);
    box-shadow: 0 8px 24px rgba(212, 160, 23, 0.08);
  }

  .value-icon {
    font-size: 2rem;
    color: var(--color-gold);
    margin-bottom: 12px;
    display: block;
  }

  .value-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 8px;
  }

  .value-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .diff-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: rgba(212, 160, 23, 0.05);
    border-radius: 8px;
    border: 1px solid rgba(212, 160, 23, 0.08);
  }

  .diff-check {
    color: var(--color-gold);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .diff-item p {
    color: var(--color-brown-light);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .story-visual {
      grid-template-columns: 1fr 1fr;
    }

    .diff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

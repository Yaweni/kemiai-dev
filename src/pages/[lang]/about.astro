---
import Layout from '../../layouts/Layout.astro';
import { loadTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = loadTranslations(lang);
const a = t.about;
const nav = t.nav;
---

<Layout title={a.heroBadge} lang={lang} t={t}>
  <section class="page-hero">
    <div class="dotted-pattern"></div>
    <div class="container">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">{a.heroBadge}</span>
      <h1 class="page-title">{a.heroTitle} <span class="gold-text">{a.heroHighlight}</span>,<br />{a.heroTitleEnd}</h1>
      <p class="page-subtitle">{a.heroSub}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <div class="floral-divider"><span>&#10086;</span></div>
          <h2 class="section-title">{a.storyTitle}</h2>
          <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 1rem; line-height: 1.8;" set:html={a.storyP1}></p>
          <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 1rem; line-height: 1.8;">{a.storyP2}</p>
          <p style="color: var(--text-secondary); font-size: 1rem; line-height: 1.8;">{a.storyP3}</p>
        </div>
        <div class="story-visual">
          <div class="story-card">
            <div class="story-stat">{a.stat1Value}</div>
            <div class="story-label">{a.stat1Label}</div>
          </div>
          <div class="story-card">
            <div class="story-stat">{a.stat2Value}</div>
            <div class="story-label">{a.stat2Label}</div>
          </div>
          <div class="story-card">
            <div class="story-stat">{a.stat3Value}</div>
            <div class="story-label">{a.stat3Label}</div>
          </div>
          <div class="story-card">
            <div class="story-stat">{a.stat4Value}</div>
            <div class="story-label">{a.stat4Label}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div style="text-align: center;">
        <div class="floral-divider"><span>&#10086;</span></div>
        <h2 class="section-title">{a.valuesTitle}</h2>
        <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">{a.valuesSub}</p>
      </div>
      <div class="grid-3">
        <div class="value-card">
          <span class="value-icon">&#10022;</span>
          <h3 class="value-title">{a.value1Title}</h3>
          <p class="value-desc">{a.value1Desc}</p>
        </div>
        <div class="value-card">
          <span class="value-icon">&#9733;</span>
          <h3 class="value-title">{a.value2Title}</h3>
          <p class="value-desc">{a.value2Desc}</p>
        </div>
        <div class="value-card">
          <span class="value-icon">&#9728;</span>
          <h3 class="value-title">{a.value3Title}</h3>
          <p class="value-desc">{a.value3Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container" style="text-align: center;">
      <div class="floral-divider" style="--gold: var(--gold-light);"><span>&#10086;</span></div>
      <h2 class="section-title" style="color: #F0EDE8;">{a.diffTitle}</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto; color: var(--text-muted);">{a.diffSub}</p>
      <div class="diff-grid">
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>{a.diff1}</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>{a.diff2}</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>{a.diff3}</p>
        </div>
        <div class="diff-item">
          <span class="diff-check">&#10004;</span>
          <p>{a.diff4}</p>
        </div>
      </div>
      <a href={`/${lang}/contact`} class="btn btn-primary" style="margin-top: 32px;">{a.diffCta}</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: var(--bg-dark);
    padding: 100px 0 72px;
    text-align: center;
    overflow: hidden;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 160, 23, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-ornament {
    color: var(--gold);
    font-size: 1rem;
    letter-spacing: 8px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    color: #F0EDE8;
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
    z-index: 1;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--gold-light), var(--amber), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .story-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    background: var(--bg-alt);
    border-radius: var(--radius);
    padding: 32px;
  }

  .story-card {
    background: var(--bg-surface);
    border: 1px solid rgba(212, 160, 23, 0.12);
    border-radius: var(--radius);
    padding: 28px 20px;
    text-align: center;
  }

  .story-stat {
    font-size: 2rem;
    font-weight: 800;
    color: var(--gold-dark);
    line-height: 1;
  }

  .story-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .value-card {
    padding: 36px 28px;
    background: var(--bg-surface);
    border-radius: var(--radius);
    border: 1px solid rgba(212, 160, 23, 0.1);
    text-align: center;
    transition: all 0.3s;
  }

  .value-card:hover {
    border-color: var(--gold);
    box-shadow: 0 8px 24px rgba(212, 160, 23, 0.08);
  }

  .value-icon {
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }

  .value-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--bg-dark);
    margin-bottom: 8px;
  }

  .value-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .diff-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: rgba(212, 160, 23, 0.05);
    border-radius: 8px;
    border: 1px solid rgba(212, 160, 23, 0.08);
  }

  .diff-check {
    color: var(--gold);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .diff-item p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .story-visual {
      grid-template-columns: 1fr 1fr;
    }

    .diff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

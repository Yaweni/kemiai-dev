---
import Layout from '../../layouts/Layout.astro';
import { loadTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = loadTranslations(lang);
const c = t.contact;
const nav = t.nav;
---

<Layout title={c.heroBadge} lang={lang} t={t} description={c.heroSub}>
  <section class="page-hero">
    <div class="dotted-pattern"></div>
    <div class="container">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">{c.heroBadge}</span>
      <h1 class="page-title">{c.heroTitle} <span class="gold-text">{c.heroHighlight}</span>{c.heroTitleEnd ? ` ${c.heroTitleEnd}` : ''}</h1>
      <p class="page-subtitle">{c.heroSub}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="floral-divider"><span>&#10086;</span></div>
          <h2 class="section-title" style="margin-bottom: 32px;">{c.sectionTitle}</h2>
          <div class="info-block">
            <div class="info-icon">&#9993;</div>
            <div>
              <h4>{c.emailLabel}</h4>
              <a href="mailto:contact@kemiai.dev">{c.emailValue}</a>
            </div>
          </div>
          <div class="info-block">
            <div class="info-icon">&#9200;</div>
            <div>
              <h4>{c.responseLabel}</h4>
              <p>{c.responseValue}</p>
            </div>
          </div>
          <div class="info-block">
            <div class="info-icon">&#127758;</div>
            <div>
              <h4>{c.locationLabel}</h4>
              <p>{c.locationValue}</p>
            </div>
          </div>
        </div>

        <form class="contact-form" action="https://formspree.io/f/mlgypazw" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">{c.nameLabel}</label>
              <input type="text" id="name" name="name" required placeholder={c.namePlaceholder} />
            </div>
            <div class="form-group">
              <label for="email">{c.emailLabel2}</label>
              <input type="email" id="email" name="email" required placeholder={c.emailPlaceholder} />
            </div>
          </div>
          <div class="form-group">
            <label for="company">{c.companyLabel}</label>
            <input type="text" id="company" name="company" placeholder={c.companyPlaceholder} />
          </div>
          <div class="form-group">
            <label for="message">{c.messageLabel}</label>
            <textarea id="message" name="message" rows="6" required placeholder={c.messagePlaceholder}></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; font-size: 1.05rem;">{c.submitBtn}</button>
          <p class="form-note">{c.privacyNote}</p>
          <p class="form-note" style="margin-top: 8px;">&mdash; or &mdash;<br /><a href="mailto:contact@kemiai.dev" class="direct-email">contact@kemiai.dev</a></p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: var(--bg-dark);
    padding: 100px 0 72px;
    text-align: center;
    overflow: hidden;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 160, 23, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-ornament {
    color: var(--gold);
    font-size: 1rem;
    letter-spacing: 8px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    color: #F0EDE8;
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
    z-index: 1;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--gold-light), var(--amber), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 64px;
    align-items: start;
  }

  .info-block {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.5rem;
    color: var(--gold);
    flex-shrink: 0;
    width: 36px;
    text-align: center;
  }

  .info-block h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .info-block p, .info-block a {
    font-size: 1rem;
    color: var(--bg-dark);
  }

  .contact-form {
    background: var(--bg-surface);
    border: 1px solid rgba(212, 160, 23, 0.15);
    border-radius: var(--radius);
    padding: 44px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    margin-bottom: 22px;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--bg-dark);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(212, 160, 23, 0.2);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: all 0.2s;
    background: #F0EDE8;
    color: var(--bg-dark);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(212, 160, 23, 0.1);
    background: var(--bg-surface);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
  }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 18px;
  }

  .direct-email {
    color: var(--gold-dark);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .direct-email:hover {
    color: var(--gold);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form {
      padding: 28px 20px;
    }
  }
</style>

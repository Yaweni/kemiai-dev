---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { loadTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = loadTranslations(lang);
const h = t.home;
const nav = t.nav;
---

<Layout title={nav.home} lang={lang} t={t} description={h.heroSub}>
  <section class="hero">
    <div class="dotted-pattern"></div>
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-ornament">&#10086; &#10086; &#10086;</div>
      <span class="hero-badge">{h.heroBadge}</span>
      <h1 class="hero-title">
        {h.heroTitle}<br />
        <span class="gold-text">{h.heroHighlight}</span>
      </h1>
      <p class="hero-subtitle">{h.heroSub}</p>
      <div class="hero-actions">
        <a href={`/${lang}/services`} class="btn btn-primary">{h.heroCta1}</a>
        <a href={`/${lang}/contact`} class="btn btn-outline-light">{h.heroCta2}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="floral-divider"><span>&#10086;</span></div>
        <h2 class="section-title">{h.servicesTitle}</h2>
        <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">
          {h.servicesSub}
        </p>
      </div>
      <div class="grid-3">
        <ServiceCard icon="&#9728;" title={h.service1Title} description={h.service1Desc} />
        <ServiceCard icon="&#9733;" title={h.service2Title} description={h.service2Desc} />
        <ServiceCard icon="&#10022;" title={h.service3Title} description={h.service3Desc} />
      </div>
      <div style="text-align: center; margin-top: 56px;">
        <a href={`/${lang}/services`} class="btn btn-primary">{h.servicesCta} &#10095;</a>
      </div>
    </div>
  </section>

  <section class="section section-dark process-section">
    <div class="container" style="text-align: center;">
      <div class="floral-divider" style="--gold: var(--gold-light);"><span>&#10086;</span></div>
      <h2 class="section-title">{h.processTitle}</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">
        {h.processSub}
      </p>
    </div>
    <div class="container">
      <div class="steps">
        <div class="step">
          <span class="step-number">1</span>
          <h3>{h.step1Title}</h3>
          <p>{h.step1Desc}</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>{h.step2Title}</h3>
          <p>{h.step2Desc}</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>{h.step3Title}</h3>
          <p>{h.step3Desc}</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <span class="step-number">4</span>
          <h3>{h.step4Title}</h3>
          <p>{h.step4Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-gold">
    <div class="container" style="text-align: center;">
      <div class="section-header">
        <div class="floral-divider" style="--gold: var(--bg-dark);"><span>&#10086;</span></div>
        <h2 class="section-title">{h.ctaTitle}</h2>
        <p class="section-subtitle" style="color: var(--text-secondary); margin-left: auto; margin-right: auto;">
          {h.ctaSub}
        </p>
      </div>
      <a href={`/${lang}/contact`} class="btn btn-primary" style="background: var(--bg-dark); color: var(--gold);">{h.ctaBtn}</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: var(--bg-dark);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 15% 50%, rgba(212, 160, 23, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 85% 50%, rgba(232, 168, 23, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(196, 126, 94, 0.06) 0%, transparent 40%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-ornament {
    color: var(--gold);
    font-size: 1.2rem;
    letter-spacing: 8px;
    margin-bottom: 24px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.1);
    color: var(--gold-light);
    padding: 6px 20px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(212, 160, 23, 0.2);
  }

  .hero-title {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.12;
    color: #F0EDE8;
    margin-bottom: 24px;
    letter-spacing: -1.5px;
  }

  .gold-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(135deg, var(--gold-light), var(--amber), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 16px;
  }

  .section-header .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .process-section {
    padding-top: 100px;
    padding-bottom: 100px;
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-top: 48px;
  }

  .step {
    flex: 1;
    text-align: center;
    padding: 0 16px;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--bg-dark);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }

  .step h3 {
    color: var(--gold-light);
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .step p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .step-connector {
    width: 40px;
    height: 2px;
    background: rgba(212, 160, 23, 0.2);
    margin-top: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.4rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .steps {
      flex-direction: column;
      gap: 32px;
    }

    .step-connector {
      display: none;
    }
  }
</style>

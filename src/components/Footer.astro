---
import type { Lang } from '../i18n';
import { localizePath } from '../i18n';

export interface Props {
  t: Record<string, any>;
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<footer class="footer">
  <div class="footer-pattern"></div>
  <div class="container footer-grid">
    <div>
      <h3 class="footer-logo">
        <span class="ornament">&#10086;</span>
        KEMI<span class="logo-accent">AI</span>
      </h3>
      <p class="footer-desc">{t.tagline}</p>
    </div>
    <div>
      <h4 class="footer-heading">{t.navTitle}</h4>
      <ul class="footer-links">
        <li><a href={localizePath(lang, '/')}>{t.home ?? 'Home'}</a></li>
        <li><a href={localizePath(lang, '/about')}>{t.about ?? 'About'}</a></li>
        <li><a href={localizePath(lang, '/services')}>{t.services ?? 'Services'}</a></li>
        <li><a href={localizePath(lang, '/contact')}>{t.contact ?? 'Contact'}</a></li>
      </ul>
    </div>
    <div>
      <h4 class="footer-heading">{t.expertiseTitle}</h4>
      <ul class="footer-links">
        <li><a href={localizePath(lang, '/services')}>{t.servicesList[0]}</a></li>
        <li><a href={localizePath(lang, '/services')}>{t.servicesList[1]}</a></li>
        <li><a href={localizePath(lang, '/services')}>{t.servicesList[2]}</a></li>
        <li><a href={localizePath(lang, '/services')}>{t.servicesList[3]}</a></li>
      </ul>
    </div>
    <div>
      <h4 class="footer-heading">{t.connectTitle}</h4>
      <ul class="footer-links">
        <li><a href="mailto:contact@kemiai.dev">contact@kemiai.dev</a></li>
        <li><a href={localizePath(lang, '/contact')}>Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} KEMI AI. {t.copyright}</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--bg-dark);
    color: var(--text-muted);
    padding: 80px 0 0;
    overflow: hidden;
  }

  .footer-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image:
      radial-gradient(circle at 20% 80%, var(--gold) 1px, transparent 1px),
      radial-gradient(circle at 80% 20%, var(--gold) 1px, transparent 1px),
      radial-gradient(circle at 40% 40%, var(--gold) 1px, transparent 1px),
      radial-gradient(circle at 60% 60%, var(--gold) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .footer-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #F0EDE8;
    margin-bottom: 12px;
  }

  .ornament {
    color: var(--gold);
    font-size: 1rem;
  }

  .logo-accent {
    color: var(--gold);
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .footer-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    max-width: 300px;
    color: var(--text-muted);
  }

  .footer-heading {
    color: var(--gold-light);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .footer-links {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 10px;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--gold);
  }

  .footer-bottom {
    position: relative;
    border-top: 1px solid rgba(212, 160, 23, 0.12);
    padding: 24px 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>

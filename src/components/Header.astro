---
import type { Lang } from '../i18n';
import { altLang, localizePath } from '../i18n';

export interface Props {
  lang: Lang;
  t: Record<string, string>;
}

const { lang, t } = Astro.props;
const otherLang = altLang(lang);
const otherLabel = lang === 'en' ? 'FR' : 'EN';
const altPath = Astro.url.pathname.replace(/^\/(en|fr)/, '');
const pages = [
  { href: localizePath(lang, '/'), label: t.home },
  { href: localizePath(lang, '/about'), label: t.about },
  { href: localizePath(lang, '/services'), label: t.services },
  { href: localizePath(lang, '/contact'), label: t.contact },
];
---

<header class="header">
  <nav class="container nav">
    <a href={localizePath(lang, '/')} class="logo">
      <span class="logo-ornament">&#10086;</span>
      KEMI<span class="logo-accent">AI</span>
    </a>

    <ul class="nav-links">
      {pages.map((p) => (
        <li><a href={p.href} class="nav-link">{p.label}</a></li>
      ))}
      <li>
        <a href={localizePath(otherLang, altPath)} class="lang-switch">{otherLabel}</a>
      </li>
      <li>
        <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
          <svg class="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </li>
    </ul>

    <a href={localizePath(lang, '/contact')} class="btn btn-primary nav-cta">{t.cta}</a>

    <button id="menu-toggle" class="menu-btn" aria-label="Menu">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </nav>

  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-inner">
      <nav class="mobile-nav">
        {pages.map((p) => (
          <a href={p.href} class="mobile-link">{p.label}</a>
        ))}
      </nav>
      <div class="mobile-actions">
        <a href={localizePath(otherLang, altPath)} class="lang-switch">{otherLabel}</a>
        <button id="theme-toggle-mobile" class="theme-btn" aria-label="Toggle theme">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </div>
      <a href={localizePath(lang, '/contact')} class="btn btn-primary mobile-cta">{t.cta}</a>
    </div>
  </div>
</header>

<script>
  (function() {
    var menuBtn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (menuBtn && menu) {
      menuBtn.addEventListener('click', function() {
        var open = menu.classList.toggle('open');
        menuBtn.classList.toggle('open');
        document.body.style.overflow = open ? 'hidden' : '';
      });
    }

    function setupThemeToggle(btnId) {
      var btn = document.getElementById(btnId);
      if (btn) {
        btn.addEventListener('click', function() {
          var html = document.documentElement;
          var cur = html.getAttribute('data-theme') || 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('kemiai-theme', next);
        });
      }
    }
    setupThemeToggle('theme-toggle');
    setupThemeToggle('theme-toggle-mobile');
  })();
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(24, 21, 18, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(212, 160, 23, 0.1);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #F0EDE8;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .logo-ornament {
    color: var(--gold);
    font-size: 1rem;
  }

  .logo-accent {
    color: var(--gold);
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 28px;
    align-items: center;
  }

  .nav-link {
    color: #A8A298;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #F0EDE8;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 32px;
    border-radius: 6px;
    background: rgba(212, 160, 23, 0.1);
    border: 1px solid rgba(212, 160, 23, 0.2);
    color: var(--gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .lang-switch:hover {
    background: var(--gold);
    color: #1A1A2E;
    border-color: var(--gold);
  }

  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid rgba(240, 237, 232, 0.12);
    color: #A8A298;
    cursor: pointer;
    transition: all 0.2s;
  }

  .theme-btn:hover {
    color: var(--gold);
    border-color: rgba(212, 160, 23, 0.3);
  }

  .sun-icon, .moon-icon { display: block; }

  [data-theme='light'] .moon-icon { display: none; }
  [data-theme='dark'] .sun-icon { display: none; }

  .nav-cta {
    padding: 10px 24px;
    font-size: 0.9rem;
  }

  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 110;
  }

  .menu-bar {
    display: block;
    width: 24px;
    height: 2px;
    background: #F0EDE8;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .menu-btn.open .menu-bar:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-btn.open .menu-bar:nth-child(2) {
    opacity: 0;
  }

  .menu-btn.open .menu-bar:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(24, 21, 18, 0.98);
    backdrop-filter: blur(16px);
    z-index: 105;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .mobile-menu.open {
    display: flex;
    opacity: 1;
  }

  .mobile-menu-inner {
    text-align: center;
    padding: 24px;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 40px;
  }

  .mobile-link {
    color: #F0EDE8;
    font-size: 1.4rem;
    font-weight: 600;
    transition: color 0.2s;
  }

  .mobile-link:hover {
    color: var(--gold);
  }

  .mobile-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .mobile-cta {
    font-size: 1.1rem;
    padding: 16px 40px;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-cta {
      display: none;
    }

    .menu-btn {
      display: flex;
    }
  }
</style>

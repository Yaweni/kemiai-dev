---
import type { Lang } from '../i18n';
import { altLang, localizePath } from '../i18n';

export interface Props {
  lang: Lang;
  t: Record<string, string>;
}

const { lang, t } = Astro.props;
const otherLang = altLang(lang);
const otherLabel = lang === 'en' ? 'FR' : 'EN';
const pages = [
  { href: localizePath(lang, '/'), label: t.home },
  { href: localizePath(lang, '/about'), label: t.about },
  { href: localizePath(lang, '/services'), label: t.services },
  { href: localizePath(lang, '/contact'), label: t.contact },
];
---

<header class="header">
  <nav class="container nav">
    <a href={localizePath(lang, '/')} class="logo">
      <span class="logo-ornament">&#10086;</span>
      KEMI<span class="logo-accent">AI</span>
    </a>
    <ul class="nav-links">
      {pages.map((p) => (
        <li><a href={p.href} class="nav-link">{p.label}</a></li>
      ))}
      <li>
        <a href={localizePath(otherLang, Astro.url.pathname.replace(/^\/(en|fr)/, ''))} class="lang-switch">{otherLabel}</a>
      </li>
      <li>
        <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
          <svg class="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </li>
    </ul>
    <a href={localizePath(lang, '/contact')} class="btn btn-primary nav-cta">{t.cta}</a>
  </nav>
</header>

<script>
  var btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', function() {
      var html = document.documentElement;
      var cur = html.getAttribute('data-theme') || 'light';
      var next = cur === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('kemiai-theme', next);
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(24, 21, 18, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(212, 160, 23, 0.1);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #F0EDE8;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .logo-ornament {
    color: var(--gold);
    font-size: 1rem;
  }

  .logo-accent {
    color: var(--gold);
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 28px;
    align-items: center;
  }

  .nav-link {
    color: #A8A298;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #F0EDE8;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 32px;
    border-radius: 6px;
    background: rgba(212, 160, 23, 0.1);
    border: 1px solid rgba(212, 160, 23, 0.2);
    color: var(--gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .lang-switch:hover {
    background: var(--gold);
    color: #1A1A2E;
    border-color: var(--gold);
  }

  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid rgba(240, 237, 232, 0.12);
    color: #A8A298;
    cursor: pointer;
    transition: all 0.2s;
  }

  .theme-btn:hover {
    color: var(--gold);
    border-color: rgba(212, 160, 23, 0.3);
  }

  .sun-icon, .moon-icon {
    display: block;
  }

  [data-theme='light'] .moon-icon { display: none; }
  [data-theme='dark'] .sun-icon { display: none; }

  .nav-cta {
    padding: 10px 24px;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-cta {
      display: none;
    }
  }
</style>
